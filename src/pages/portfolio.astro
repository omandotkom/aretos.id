---
import MainLayout from "../layouts/MainLayout.astro";
import { breadcrumbSchema, webPageSchema } from "../lib/structured-data";
import projects from "../data/portfolio.json";
---

<MainLayout
  title="Portfolio | aretos.id"
  description="Studi kasus website dan aplikasi yang dikerjakan aretos.id beserta dampak bisnisnya."
  canonicalPath="/portfolio"
  keywords={["portfolio website", "studi kasus web app", "jasa aplikasi bisnis"]}
  structuredData={[
    webPageSchema(
      "Portfolio | aretos.id",
      "Studi kasus website dan aplikasi yang dikerjakan aretos.id beserta dampak bisnisnya.",
      "/portfolio"
    ),
    breadcrumbSchema([
      { name: "Beranda", path: "/" },
      { name: "Portfolio", path: "/portfolio" }
    ])
  ]}
>
  <section class="section reveal">
    <div class="container reveal-delay-1">
      <span class="eyebrow">Portfolio</span>
      <h1>Studi kasus dengan tantangan nyata dan hasil yang terukur.</h1>
      <p class="lead">Format kerja kami selalu berangkat dari masalah bisnis, bukan langsung lompat ke teknologi.</p>
      <div class="grid-3 portfolio-grid">
        {
          projects.map((project, index) => (
            <article class={`card hover-lift portfolio-card reveal-delay-${Math.min(index + 1, 3)}`}>
              <figure class="portfolio-thumb">
                <img src={project.image} alt={project.imageAlt} loading="lazy" />
              </figure>
              <h3>{project.title}</h3>
              <p><strong>Tantangan:</strong> {project.challenge}</p>
              <p><strong>Solusi:</strong> {project.solution}</p>
              <p><strong>Hasil:</strong> {project.impact}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>
