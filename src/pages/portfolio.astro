---
import MainLayout from "../layouts/MainLayout.astro";
import { breadcrumbSchema, webPageSchema } from "../lib/structured-data";

const projects = [
  {
    title: "Retail Ops Dashboard",
    challenge: "Stok dan pembelian tercatat di spreadsheet terpisah.",
    solution: "Dashboard terpusat untuk stok, procurement, dan laporan mingguan otomatis.",
    impact: "Waktu rekap turun dari 6 jam menjadi 45 menit per minggu."
  },
  {
    title: "Lead Capture Landing System",
    challenge: "Tim sales kehilangan lead dari berbagai channel.",
    solution: "Landing page + form terintegrasi ke CRM dan notifikasi real-time ke WhatsApp.",
    impact: "Waktu respons lead turun ke rata-rata 12 menit."
  },
  {
    title: "Internal Approval Platform",
    challenge: "Approval pengeluaran lambat karena alur manual.",
    solution: "Web app approval multi-level dengan log aktivitas dan audit trail.",
    impact: "Siklus approval menjadi 2x lebih cepat dalam 1 bulan pertama."
  }
];
---

<MainLayout
  title="Portfolio | aretos.id"
  description="Studi kasus website dan aplikasi yang dikerjakan aretos.id beserta dampak bisnisnya."
  canonicalPath="/portfolio"
  keywords={["portfolio website", "studi kasus web app", "jasa aplikasi bisnis"]}
  structuredData={[
    webPageSchema(
      "Portfolio | aretos.id",
      "Studi kasus website dan aplikasi yang dikerjakan aretos.id beserta dampak bisnisnya.",
      "/portfolio"
    ),
    breadcrumbSchema([
      { name: "Beranda", path: "/" },
      { name: "Portfolio", path: "/portfolio" }
    ])
  ]}
>
  <section class="section reveal">
    <div class="container reveal-delay-1">
      <span class="eyebrow">Portfolio</span>
      <h1>Studi kasus dengan tantangan nyata dan hasil yang terukur.</h1>
      <p class="lead">Format kerja kami selalu berangkat dari masalah bisnis, bukan langsung lompat ke teknologi.</p>
      <div class="grid-3">
        {
          projects.map((project, index) => (
            <article class={`card hover-lift reveal-delay-${Math.min(index + 1, 3)}`}>
              <h3>{project.title}</h3>
              <p><strong>Tantangan:</strong> {project.challenge}</p>
              <p><strong>Solusi:</strong> {project.solution}</p>
              <p><strong>Hasil:</strong> {project.impact}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>
