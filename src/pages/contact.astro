---
import MainLayout from "../layouts/MainLayout.astro";
import { absoluteUrl, breadcrumbSchema, webPageSchema } from "../lib/structured-data";

const contactSchema = {
  "@type": "ContactPage",
  name: "Kontak aretos.id",
  url: absoluteUrl("/contact"),
  description: "Halaman kontak aretos.id untuk diskusi kebutuhan website atau aplikasi bisnis.",
  mainEntity: {
    "@type": "Organization",
    name: "aretos.id",
    email: "hello@aretos.id",
    telephone: "+6281318726585"
  }
};
---

<MainLayout
  title="Kontak | aretos.id"
  description="Hubungi aretos.id untuk konsultasi kebutuhan website atau aplikasi bisnis."
  canonicalPath="/contact"
  keywords={["kontak jasa website", "konsultasi aplikasi bisnis", "hubungi software house"]}
  structuredData={[
    webPageSchema(
      "Kontak | aretos.id",
      "Hubungi aretos.id untuk konsultasi kebutuhan website atau aplikasi bisnis.",
      "/contact"
    ),
    breadcrumbSchema([
      { name: "Beranda", path: "/" },
      { name: "Kontak", path: "/contact" }
    ]),
    contactSchema
  ]}
>
  <section class="section reveal">
    <div class="container reveal-delay-1">
      <span class="eyebrow">Konsultasi</span>
      <h1>Ceritakan kebutuhan Anda, kami bantu susun scope yang masuk akal.</h1>
      <p class="lead">Sesi awal digunakan untuk memahami prioritas bisnis, estimasi timeline, dan opsi implementasi.</p>
      <div class="grid-2">
        <article class="card hover-lift reveal-delay-1">
          <h3>Kontak cepat</h3>
          <p>Email: <a href="mailto:hello@aretos.id">hello@aretos.id</a></p>
          <p>WhatsApp: <a href="https://wa.me/6281318726585">+62 813-1872-6585</a></p>
          <p>
            <a
              href="https://wa.me/6281318726585?text=Halo%20aretos.id%2C%20perkenalkan%20saya%20%5BNama%5D%20dari%20%5BPerusahaan%5D.%20Saya%20ingin%20konsultasi%20terkait%20kebutuhan%20pengembangan%20website%2Faplikasi%20untuk%20bisnis%20kami.%20Mohon%20informasi%20ketersediaan%20jadwal%20diskusi%20dalam%20waktu%20dekat.%20Terima%20kasih."
              class="btn btn-primary"
            >
              Mulai Konsultasi via WhatsApp
            </a>
          </p>
          <p>Jam kerja: Senin - Jumat, 09:00 - 18:00 WIB</p>
        </article>
        <article class="card hover-lift reveal-delay-2">
          <h3>Format brief agar diskusi cepat</h3>
          <p>1. Tujuan bisnis yang ingin dicapai dari project.</p>
          <p>2. Fitur inti yang wajib ada di versi pertama.</p>
          <p>3. Estimasi timeline dan budget range yang tersedia.</p>
          <p>4. Deadline khusus atau event penting terkait launch.</p>
        </article>
      </div>
    </div>
  </section>
</MainLayout>
